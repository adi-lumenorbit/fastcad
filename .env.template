# fastcad — environment template.
#
# Copy to `.env` (gitignored) and fill in real values. `scripts/dev.sh`
# sources `.env` automatically when starting the dev server.
#
# DO NOT commit `.env`. Anything in it is treated as a secret.

# --- Required for real-Claude mode ---

# Anthropic API key. Get one at https://console.anthropic.com/settings/keys
# (separate from claude.ai accounts; needs API billing enabled).
# Format: sk-ant-...
ANTHROPIC_API_KEY=

# --- Optional ---

# Skip the network entirely; use deterministic regex agent. Set to 1 for
# offline development / testing. Leave unset for real-Claude mode.
# ANTHROPIC_FAKE=1

# Override the default model. Defaults to claude-sonnet-4-6.
# FASTCAD_MODEL=claude-sonnet-4-6

# Cap on tool-use iterations per turn. Defaults to 8.
# FASTCAD_MAX_TOOL_ITER=8

# Dev server bind. Defaults host=0.0.0.0 port=8765 (so WSL reaches Windows).
# FASTCAD_HOST=0.0.0.0
# FASTCAD_PORT=8765
